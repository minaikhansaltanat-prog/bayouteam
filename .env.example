# ── Supabase (міндетті) ──────────────────────────────────────────────
# Supabase жобасын https://supabase.com/dashboard жерінен тегін жасаңыз.
# Settings → API бетінен көшіріңіз.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Settings → API → service_role (құпия, тек серверде қолданылады, .env.local-де ғана сақтаңыз)
SUPABASE_SERVICE_ROLE_KEY=

# ── Google OAuth (кіру үшін міндетті) ────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth Client ID
# Supabase Dashboard → Authentication → Providers → Google бөлімінде де
# осы Client ID/Secret орнатылуы керек, redirect URL:
# https://<PROJECT_REF>.supabase.co/auth/v1/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AI (V1/V2 кезеңі — Whisper транскрибация, GPT кеңестер) ──────────
OPENAI_API_KEY=

# ── Email хабарламалар (V1 кезеңі) ────────────────────────────────────
RESEND_API_KEY=

# ── WhatsApp хабарламалар (V1 кезеңі, Meta Business) ──────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# ── Дизайн/QA — тек әзірлеу кезінде ────────────────────────────────────
# "1" болса, нақты Supabase/Google OAuth болмаса да, интерфейсті үлгі
# деректермен шолуға болады (bayou-team/lib/dev/mock-data.ts).
# Production-ға шығарар алдында бұл жолды МІНДЕТТІ түрде өшіріңіз.
NEXT_PUBLIC_DEV_PREVIEW=
